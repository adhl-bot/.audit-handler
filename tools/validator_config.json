{
  "defaults": {
    "audit_dir": "audits/audits_uniq_id",
    "auxiliary_doc": "auxiliary_descriptions_without_unique_naming.md"
  },
  "naming": {
    "field_order": [
      "control_id",
      "os",
      "os_version",
      "role",
      "benchmark_version",
      "level",
      "title"
    ],
    "allowed_values": {
      "os": ["MS", "OL", "N/A"],
      "os_version": ["2016", "2019", "2022", "W11", "8", "N/A"],
      "role": ["DM", "DC", "N/A"],
      "benchmark_version": ["v0.0.0", "v4.0.0", "v5.0.0"],
      "level": ["L1", "L2"]
    }
  },
  "reference": {
    "allow_unknown_control_fields": false,
    "groups": {
      "common": [
        {
          "name": "CONTROL_IG",
          "type": "enum",
          "allowed_values": ["IG1", "IG2", "IG3"]
        },
        {
          "name": "CONTROL_INTERNAL_VERSION",
          "type": "integer",
          "min": 0
        },
        {
          "name": "CONTROL_CUSTOMER",
          "type": "boolean"
        },
        {
          "name": "CONTROL_CIS",
          "type": "boolean"
        }
      ],
      "windows_server": [
        {
          "name": "CONTROL_MS_ONLY",
          "type": "boolean"
        },
        {
          "name": "CONTROL_DC_ONLY",
          "type": "boolean"
        }
      ]
    },
    "allowed_customer_cis_pairs": [
      ["false", "true"],
      ["true", "false"]
    ]
  },
  "roles": {
    "windows_server_member_roles": ["DM"],
    "windows_server_dc_roles": ["DC"],
    "neutral_roles": ["N/A"]
  },
  "families": [
    {
      "name": "windows_server_2016",
      "file_pattern": ".*Windows_Server_2016.*\\.audit$",
      "expected": {
        "os": "MS",
        "os_version": "2016",
        "roles": ["DM", "DC", "N/A"],
        "benchmark_version": "v4.0.0",
        "level": "L1"
      },
      "reference_groups": ["common", "windows_server"],
      "requires_unified_role_detection": true,
      "role_detection": [
        {
          "name": "any_windows_server_role",
          "domain_role_values": [2, 3, 4, 5]
        },
        {
          "name": "member_server_branch",
          "domain_role_values": [2, 3]
        },
        {
          "name": "domain_controller_branch",
          "domain_role_values": [4, 5]
        }
      ]
    },
    {
      "name": "windows_server_2019",
      "file_pattern": ".*Windows_Server_2019.*\\.audit$",
      "expected": {
        "os": "MS",
        "os_version": "2019",
        "roles": ["DM", "DC", "N/A"],
        "benchmark_version": "v4.0.0",
        "level": "L1"
      },
      "reference_groups": ["common", "windows_server"],
      "requires_unified_role_detection": true,
      "role_detection": [
        {
          "name": "any_windows_server_role",
          "domain_role_values": [2, 3, 4, 5]
        },
        {
          "name": "member_server_branch",
          "domain_role_values": [2, 3]
        },
        {
          "name": "domain_controller_branch",
          "domain_role_values": [4, 5]
        }
      ]
    },
    {
      "name": "windows_server_2022",
      "file_pattern": ".*Windows_Server_2022.*\\.audit$",
      "expected": {
        "os": "MS",
        "os_version": "2022",
        "roles": ["DM", "DC", "N/A"],
        "benchmark_version": "v5.0.0",
        "level": "L1"
      },
      "reference_groups": ["common", "windows_server"],
      "requires_unified_role_detection": true,
      "role_detection": [
        {
          "name": "any_windows_server_role",
          "domain_role_values": [2, 3, 4, 5]
        },
        {
          "name": "member_server_branch",
          "domain_role_values": [2, 3]
        },
        {
          "name": "domain_controller_branch",
          "domain_role_values": [4, 5]
        }
      ]
    },
    {
      "name": "windows_11_stand_alone",
      "file_pattern": ".*Windows_11.*\\.audit$",
      "expected": {
        "os": "MS",
        "os_version": "W11",
        "roles": ["N/A"],
        "benchmark_version": "v4.0.0",
        "level": "L1"
      },
      "reference_groups": ["common"],
      "forbidden_reference_fields": ["CONTROL_MS_ONLY", "CONTROL_DC_ONLY"]
    },
    {
      "name": "oracle_linux_8",
      "file_pattern": ".*Oracle_Linux_8.*\\.audit$",
      "expected": {
        "os": "OL",
        "os_version": "8",
        "roles": ["N/A"],
        "benchmark_version": "v4.0.0",
        "level": "L1"
      },
      "reference_groups": ["common"],
      "forbidden_reference_fields": ["CONTROL_MS_ONLY", "CONTROL_DC_ONLY"]
    }
  ]
}
